# Vonage credentials
VONAGE_APPLICATION_ID=your_application_id_here
VONAGE_PRIVATE_KEY_PATH=private.key
VONAGE_FROM_NUMBER=your_vonage_number_here

# Default phone number to call for alarms (can also override with --phone flag)
PHONE_NUMBER=919056690327

# Discord bot token — get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord guild ID for instant slash command registration (optional)
# Leave empty to sync globally (takes up to 1 hour)
DISCORD_GUILD_ID=

# Webhook URL — must be publicly accessible by Vonage
# For local dev use ngrok: ngrok http 8080
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io
WEBHOOK_PORT=8080
